PORT=3000

# Prisma: genau eine DATABASE_URL aktiv setzen.
#
# Produktion (Daten auf deinem Server): Postgres auf dem VPS, z. B. nach docker compose up -d:
# DATABASE_URL=postgresql://postgres:DEIN_PASS@127.0.0.1:5432/postgres
#
# Lokal — Supabase CLI (npx supabase start), Port siehe supabase/config.toml:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
# Lokal — nur Postgres: postgresql://postgres:postgres@localhost:5432/postgres + bun run db:up
#
# Optional — Daten bei Supabase Cloud (nur wenn gewollt): …@db.xxx.supabase.co:5432/postgres?sslmode=require

# Optional: APIs von anderer Origin
# ALLOWED_ORIGIN=https://ihre-domain.de
# RATE_LIMIT_DISABLED=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword

ADMIN_USER=admin
ADMIN_PASS=yourpassword
ADMIN_USERS=[{"user":"admin","pass":"yourpassword"}]
