PORT=3000
DATABASE_URL=postgresql://user:password@localhost:5432/dbname

# Optional: nur nötig, wenn das Formular per JS von einer anderen Origin die APIs aufruft
# ALLOWED_ORIGIN=https://ihre-domain.de
# Optional: setzt IP-Rate-Limiting komplett außer Kraft (Login + Kontaktformular)
# RATE_LIMIT_DISABLED=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword

ADMIN_USER=admin
ADMIN_PASS=yourpassword
ADMIN_USERS=[{"user":"admin","pass":"yourpassword"}]
