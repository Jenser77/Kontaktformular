PORT=3000

# Lokal empfohlen: Supabase CLI (npx supabase start), Port siehe supabase/config.toml:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
# Alternative nur Postgres: postgresql://postgres:postgres@localhost:5432/postgres + bun run db:up
# Supabase Cloud (Direct): postgresql://postgres:PASS@db.xxx.supabase.co:5432/postgres?sslmode=require

# Optional: APIs von anderer Origin
# ALLOWED_ORIGIN=https://ihre-domain.de
# RATE_LIMIT_DISABLED=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword

ADMIN_USER=admin
ADMIN_PASS=yourpassword
ADMIN_USERS=[{"user":"admin","pass":"yourpassword"}]
