PORT=3000

# Server-Logs (pino): trace | debug | info | warn | error | silent. Standard: info (prod) / debug (dev).
# LOG_LEVEL=info

# Prisma: genau eine DATABASE_URL aktiv setzen.
#
# Produktion: /etc/kontaktformular.env (chmod 600), NICHT diese Datei!
# DATABASE_URL=postgresql://postgres:STARKES_PASSWORT@127.0.0.1:5432/postgres
#
# Lokal — Supabase CLI (npx supabase start), Port siehe supabase/config.toml:
DATABASE_URL=postgresql://postgres:postgres@127.0.0.1:55322/postgres
# Lokal — nur Postgres: postgresql://postgres:postgres@localhost:5432/postgres + bun run db:up

# Optional: Postgres-Pool (Standard 10)
# PG_POOL_MAX=10

# Öffentliche Origin der Hauptseite (CORS). Lokal nicht nötig.
# ALLOWED_ORIGIN=https://www.firma.de

# RATE_LIMIT_DISABLED=true

# Persistentes Rate Limiting (Produktion empfohlen). Ohne diese Variablen: In-Memory pro Prozess.
# UPSTASH_REDIS_REST_URL=https://xxxx.upstash.io
# UPSTASH_REDIS_REST_TOKEN=...

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword

# Admin: nur Datenbank (bcrypt). Anlegen mit: bun run create-admin <username> <passwort> [Anzeigename]
