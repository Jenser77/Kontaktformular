PORT=3000

# Eine Zeile — lokal z. B. Docker (docker compose up -d):
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/postgres
# Oder Supabase (Direct, Port 5432): postgresql://postgres:PASS@db.xxx.supabase.co:5432/postgres?sslmode=require

# Optional: APIs von anderer Origin
# ALLOWED_ORIGIN=https://ihre-domain.de
# RATE_LIMIT_DISABLED=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=user@example.com
SMTP_PASS=yourpassword

ADMIN_USER=admin
ADMIN_PASS=yourpassword
ADMIN_USERS=[{"user":"admin","pass":"yourpassword"}]
