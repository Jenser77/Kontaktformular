generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Contact {
  id                    String   @id @default(uuid())
  firstName             String
  lastName              String
  organization          String?
  email                 String
  phone                 String?
  subject               String
  message               String
  privacyAccepted       Boolean
  targetRecipient       String?
  /// Snapshot at submit time: "Mandant → Einrichtung → Abteilung"
  targetRecipientLabel  String?
  createdAt             DateTime @default(now())
  deletedAt             DateTime?

  @@index([createdAt])
  @@index([targetRecipient])
  @@index([deletedAt])
}

model Mandant {
  id            String        @id @default(uuid())
  name          String
  einrichtungen Einrichtung[]
  createdAt     DateTime      @default(now())
}

model Einrichtung {
  id            String          @id @default(uuid())
  name          String
  mandantId     String
  mandant       Mandant         @relation(fields: [mandantId], references: [id], onDelete: Cascade)
  abteilungen   Fachabteilung[]
  createdAt     DateTime        @default(now())
}

model Fachabteilung {
  id            String      @id @default(uuid())
  name          String
  email         String
  einrichtungId String
  einrichtung   Einrichtung @relation(fields: [einrichtungId], references: [id], onDelete: Cascade)
  createdAt     DateTime    @default(now())
}

model AdminUser {
  id           String         @id @default(uuid())
  username     String         @unique
  displayName  String?
  passwordHash String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  sessions     AdminSession[]
}

model AdminSession {
  id          String     @id
  expiresAt   DateTime
  createdAt   DateTime   @default(now())
  adminUserId String?
  adminUser   AdminUser? @relation(fields: [adminUserId], references: [id], onDelete: Cascade)
  loginLabel  String?

  @@index([expiresAt])
  @@index([adminUserId])
}
